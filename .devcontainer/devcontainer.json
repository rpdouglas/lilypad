{
  "name": "Lily Pad Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/firebase-cli:1": {}
  },
  "postCreateCommand": "npm ci && firebase setup:emulators:firestore",
  "forwardPorts": [5173, 4000, 9099, 9199],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "openPreview"
    },
    "4000": {
      "label": "Firebase Emulator UI",
      "onAutoForward": "notify"
    },
    "9099": {
      "label": "Firebase Auth Emulator",
      "onAutoForward": "silent"
    },
    "9199": {
      "label": "Firebase Storage Emulator",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
        "dbaeumer.vscode-eslint",
        "formulahendry.auto-rename-tag",
        "christian-kohler.path-intellisense",
        "PKief.material-icon-theme",
        "GitHub.copilot-chat"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "editor.rulers": [80],
        "tailwindCSS.experimental.classRegex": [
          ["clsx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
          ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
        ],
        "js/ts.preferences.importModuleSpecifier": "relative",
        "js/ts.updateImportsOnFileMove.enabled": "always",
        "emmet.includeLanguages": {
          "typescript": "html",
          "typescriptreact": "html"
        }
      }
    }
  },
  "remoteEnv": {
    "VITE_FIREBASE_API_KEY":             "${localEnv:VITE_FIREBASE_API_KEY}",
    "VITE_FIREBASE_AUTH_DOMAIN":         "${localEnv:VITE_FIREBASE_AUTH_DOMAIN}",
    "VITE_FIREBASE_PROJECT_ID":          "${localEnv:VITE_FIREBASE_PROJECT_ID}",
    "VITE_FIREBASE_STORAGE_BUCKET":      "${localEnv:VITE_FIREBASE_STORAGE_BUCKET}",
    "VITE_FIREBASE_MESSAGING_SENDER_ID": "${localEnv:VITE_FIREBASE_MESSAGING_SENDER_ID}",
    "VITE_FIREBASE_APP_ID":              "${localEnv:VITE_FIREBASE_APP_ID}"
  }
}